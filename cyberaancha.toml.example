# Copy to cyberaancha.toml (gitignored). No secrets here — secrets live in the DB
# via `cyberaancha-server set-password` / `gen-token` (SPEC §13).

[channel]
handle = "@vanyserezhkin" # production: "@AnchaBaranovaProf"

# User-facing identity — the product isn't hardcoded to one person. All optional;
# omit for generic defaults (brand derived from the handle, "автора", plain
# disclaimer). Production (Ancha) instance sets:
[owner]
name = "Ancha Baranova"                                                              # English / MCP
ref = "профессора"                                                                   # "Мнение <ref>:" (genitive)
disclaimer = "Справочный материал по выступлениям проф. Барановой, не медицинская рекомендация."
brand = "cyberaancha"                                                                     # panel title; omit → derived from handle

[server]
bind = "127.0.0.1:8087"
public_url = "https://aancha.serezhkin.com"
data_dir = "data"
index_dir = "index"

[harvest]
window_days = 7 # one wave = one week of publish dates
pace_ms = 1500

[index]
writer_heap_mb = 96 # n1 has 457 MB total — stay small

[backup]
dir = "backups"
hour_utc = 3
keep = 3
