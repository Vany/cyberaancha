{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "harvest_captions result",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["yt_id", "none"],
      "properties": {
        "yt_id": { "type": "string", "pattern": "^[0-9A-Za-z_-]{11}$" },
        "none": { "const": true }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["yt_id", "lang", "source", "segments"],
      "properties": {
        "yt_id": { "type": "string", "pattern": "^[0-9A-Za-z_-]{11}$" },
        "lang": { "type": "string", "maxLength": 10 },
        "source": { "enum": ["asr", "manual"] },
        "segments": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["t_ms", "text"],
            "properties": {
              "t_ms": { "type": "integer", "minimum": 0 },
              "d_ms": { "type": ["integer", "null"], "minimum": 0 },
              "text": { "type": "string", "maxLength": 2000 }
            }
          }
        }
      }
    }
  ]
}
